{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: CLI - Version (INFO)",
            "type": "debugpy",
            "request": "launch",
            "module": "auto_lorebook",
            "args": [
                "-v",
                "version"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: CLI - Example Command (INFO)",
            "type": "debugpy",
            "request": "launch",
            "module": "auto_lorebook",
            "args": [
                "-v",
                "example",
                "World",
                "--greeting",
                "Hello"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}"
        }
    ]
}